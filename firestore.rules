rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────

    // True if the request is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Fetch the caller's user document from Firestore
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // True if the caller has a specific role key (e.g. 'admin', 'head_nurse')
    function hasRoleKey(key) {
      return isAuth() && userDoc().roleKeys != null && userDoc().roleKeys.hasAny([key]);
    }

    // True if the caller is an admin (has 'admin' role key)
    function isAdmin() {
      return hasRoleKey('admin');
    }

    // True if caller is admin or head_nurse
    function isAdminOrHeadNurse() {
      return hasRoleKey('admin') || hasRoleKey('head_nurse');
    }

    // True if the caller is active
    function isActive() {
      return isAuth() && userDoc().status == 'active';
    }

    // ─────────────────────────────────────────────────────────
    // /users/{userId}
    // ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated active user can read their own profile.
      // Admins and head nurses can read all profiles.
      allow read: if isAuth() && (
        request.auth.uid == userId || isAdminOrHeadNurse()
      );

      // Only admins can create / delete user documents.
      allow create, delete: if isAdmin();

      // Users can update their own profile (except roles/status/employeeCode).
      // Admins can update any field on any profile.
      allow update: if isAdmin() || (
        isActive() &&
        request.auth.uid == userId &&
        !('roles' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('roleKeys' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('status' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('employeeCode' in request.resource.data.diff(resource.data).affectedKeys())
      );
    }

    // ─────────────────────────────────────────────────────────
    // /pendingUsers/{pendingId}
    // ─────────────────────────────────────────────────────────
    match /pendingUsers/{pendingId} {
      // A pending user can read their own record.
      // Admins and head nurses can read all pending requests.
      allow read: if isAuth() && (
        request.auth.uid == pendingId || isAdminOrHeadNurse()
      );

      // Anyone authenticated can create their own pending record (Google sign-up flow).
      allow create: if isAuth() && request.auth.uid == pendingId;

      // Only admins can update (approve / reject) pending records.
      allow update: if isAdmin();

      // Only admins can delete pending records.
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /employeeCredentials/{employeeId}
    // ─────────────────────────────────────────────────────────
    match /employeeCredentials/{employeeId} {
      // Employees can read their own credentials.
      allow read: if isAuth() && request.auth.uid == employeeId;

      // Only admins can create/update/delete credentials.
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /roles/{roleId}
    // ─────────────────────────────────────────────────────────
    match /roles/{roleId} {
      // All authenticated active users can read roles
      // (needed so the UI can display role names and permissions).
      allow read: if isActive();

      // Only admins can create/update/delete roles.
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /departments/{deptId}
    // ─────────────────────────────────────────────────────────
    match /departments/{deptId} {
      // All authenticated active users can read departments.
      allow read: if isActive();

      // Only admins can manage departments.
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /settings/{docId}
    // ─────────────────────────────────────────────────────────
    match /settings/{docId} {
      // All authenticated active users can read global settings.
      allow read: if isActive();

      // Only admins can write settings.
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /loginLogs/{logId}
    // ─────────────────────────────────────────────────────────
    match /loginLogs/{logId} {
      // Any authenticated user can create their own log entry.
      allow create: if isAuth();

      // Only admins can read and delete log entries.
      allow read, delete: if isAdmin();

      // Log entries are immutable — no updates.
      allow update: if false;
    }

    // ─────────────────────────────────────────────────────────
    // Deny everything else
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

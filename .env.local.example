# ══════════════════════════════════════════════════════
#   PRO Nurse — Environment Variables Template
#   انسخ هذا الملف إلى .env.local واملأ القيم
# ══════════════════════════════════════════════════════

# ─── Firebase Configuration ────────────────────────────
# احصل على هذه القيم من: https://console.firebase.google.com
# → Project Settings → General → Your apps → Web app

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ─── WhatsApp Business API (Meta) ──────────────────────
# احصل على التوكن من: https://developers.facebook.com → WhatsApp → API Setup
# الرابط الأساسي: https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID
# إذا تركت هذا فارغاً سيفتح تطبيق واتساب مباشرةً (wa.me link)

NEXT_PUBLIC_WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID
NEXT_PUBLIC_WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxxx

# ─── الخطوات لتفعيل تسجيل الدخول بـ Google ────────────
# 1. اذهب إلى Firebase Console → Authentication → Sign-in method
# 2. فعّل Google provider
# 3. أضف نطاق موقعك في Authorized domains
# 4. انسخ إعدادات Firebase أعلاه
